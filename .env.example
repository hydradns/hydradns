# HydraDNS Environment Variables

# Core service
PHANTOM_CONFIG=/app/configs/config.yaml
PHANTOM_DB=/app/data/phantomdns.db
PHANTOM_POLICIES=/app/configs/policies.json

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# UI
NEXT_PUBLIC_API_URL=http://localhost:8080
